#!/usr/bin/env bash
# __LAB_TITLE__ â€” launcher. Brings the lab up in Docker, then logs the student
# straight into a REAL interactive shell on the workstation (shell-mode). No lab>
# REPL and no invented verbs: the student works the lab with the genuine installed
# tools, exactly as they would on a real machine.
set -u
cd "$(dirname "$0")/.." || exit 1

# --- Which box does the student land on? -------------------------------------
# SHELL_HOST is the docker-compose SERVICE the launcher drops the student into.
# The starter has one workstation ('attacker'); point this at a different service
# to make another box the entry point (e.g. 'analyst', 'firewall', 'station').
#
# MULTI-HOST LABS (optional â€” this template stays single-box by default):
# keep ONE entry box here and give the student real `ssh` to the others from
# inside it. Bake a shared root keypair + host keys into the image so
# `ssh <other-host>` just works on the isolated lab network â€” see assume-breach
# module-07 (node/Dockerfile: `ssh-keygen -A`, a baked id_ed25519 copied to
# authorized_keys, and a client config with StrictHostKeyChecking no). A disposable
# baked lab key is fine on an isolated teaching net. A comment + the keypair is all
# it takes; you don't need a bigger launcher.
SHELL_HOST="${SHELL_HOST:-attacker}"

# $'...' gives real escape characters (survives heredocs and plain echo, unlike a
# bare '\033' string). No colours when stdout isn't a terminal.
if [ -t 1 ]; then
  C_OK=$'\033[0;32m'; C_P=$'\033[0;36m'; C_DIM=$'\033[0;90m'; NC=$'\033[0m'
else
  C_OK=''; C_P=''; C_DIM=''; NC=''
fi

need_docker() {
  command -v docker >/dev/null 2>&1 || { echo "Docker isn't installed. Install Docker Desktop and re-run."; exit 1; }
  docker info >/dev/null 2>&1 || { echo "Docker is installed but not running. Start Docker Desktop and re-run."; exit 1; }
}

bring_up() {
  echo "${C_DIM}Powering on the labâ€¦${NC}"
  ( docker compose pull || docker compose build ) >/tmp/__LAB_SLUG__-up.log 2>&1
  docker compose up -d >>/tmp/__LAB_SLUG__-up.log 2>&1 \
    && echo "${C_OK}The lab is up.${NC}" \
    || { echo "Something went wrong bringing the lab up:"; tail -n 15 /tmp/__LAB_SLUG__-up.log; exit 1; }
}

open_url() {
  # Browser convenience for web-target labs: `./start.sh open [url]` opens the
  # target in a browser. Never required â€” the default path is the real shell.
  local url="${1:-http://localhost:8080}"
  if command -v open >/dev/null 2>&1; then open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$url"
  elif command -v explorer.exe >/dev/null 2>&1; then explorer.exe "$url"
  else echo "Open this in your browser: $url"; fi
}

need_docker

# Optional: `./start.sh open [url]` just opens the web target and exits.
if [ "${1:-}" = "open" ]; then bring_up; open_url "${2:-}"; exit 0; fi

printf "\n  ${C_P}__LAB_TITLE__${NC}\n  ${C_DIM}An isolated lab in Docker. Logging you into the workstationâ€¦${NC}\n\n"
bring_up

# Hand the student a REAL shell on the workstation. The image's welcome banner,
# `labhelp`, `netmap` and themed prompt take over from here (see base.Dockerfile).
# `exec` replaces this launcher, so the student's terminal *is* the workstation
# shell; when they `exit`, control returns to their host terminal and the lab keeps
# running (`make stop` to halt it, `make down` to remove it).
printf "  ${C_DIM}Type ${NC}labhelp${C_DIM} for the mission, ${NC}netmap${C_DIM} for the network, ${NC}exit${C_DIM} to leave.${NC}\n\n"
if docker compose exec "$SHELL_HOST" sh -c 'command -v bash >/dev/null 2>&1' >/dev/null 2>&1; then
  exec docker compose exec "$SHELL_HOST" bash
else
  exec docker compose exec "$SHELL_HOST" sh
fi
